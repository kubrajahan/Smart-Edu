rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Default Deny Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserEmail() {
      return request.auth.token.email;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Check if the user is a school staff (SuperAdmin, Teacher, Principal)
    // Note: Default to true for authenticated development workspace users, but check email
    function isStaff() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        getUserEmail() != null
      );
    }

    // Students collection rules
    match /students/{studentId} {
      allow read: if isSignedIn();
      allow write: if isStaff() && isValidId(studentId);
    }

    // Teachers collection rules
    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow write: if isStaff() && isValidId(teacherId);
    }

    // LibraryBooks collection rules
    match /libraryBooks/{bookId} {
      allow read: if isSignedIn();
      allow write: if isStaff() && isValidId(bookId);
    }

    // Timetable collection rules
    match /timetable/{slotId} {
      allow read: if isSignedIn();
      allow write: if isStaff() && isValidId(slotId);
    }
  }
}
