rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Default Deny Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Students collection rules
    match /students/{studentId} {
      allow read, write: if isValidId(studentId);
    }

    // Teachers collection rules
    match /teachers/{teacherId} {
      allow read, write: if isValidId(teacherId);
    }

    // LibraryBooks collection rules
    match /libraryBooks/{bookId} {
      allow read, write: if isValidId(bookId);
    }

    // Timetable collection rules
    match /timetable/{slotId} {
      allow read, write: if isValidId(slotId);
    }

    // School State collection rules (used by full-stack server for database persistence backup)
    match /school_state/{docId} {
      allow read, write: if isValidId(docId);
    }

    // Test collection rules for connection health check
    match /test/{docId} {
      allow read, write: if isValidId(docId);
    }
  }
}
