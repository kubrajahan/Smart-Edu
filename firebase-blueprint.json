{
  "entities": {
    "student": {
      "title": "Student",
      "description": "A representation of a student and their school enrollment, attendance, grades, and fees.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "rollNumber": { "type": "string" },
        "grade": { "type": "string" },
        "gender": { "type": "string" },
        "parentName": { "type": "string" },
        "parentEmail": { "type": "string" },
        "parentPhone": { "type": "string" },
        "attendanceRate": { "type": "number" },
        "riskLevel": { "type": "string" }
      },
      "required": ["id", "name", "rollNumber", "grade"]
    },
    "teacher": {
      "title": "Teacher",
      "description": "An institutional educator.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" }
      },
      "required": ["id", "name", "email", "subject"]
    },
    "libraryBook": {
      "title": "LibraryBook",
      "description": "A catalogued school book.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "isbn": { "type": "string" },
        "category": { "type": "string" },
        "totalCopies": { "type": "number" },
        "issuedCopies": { "type": "number" }
      },
      "required": ["id", "title", "author", "isbn"]
    },
    "timetableEntry": {
      "title": "TimetableEntry",
      "description": "A scheduled course slot for a grade.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "grade": { "type": "string" },
        "day": { "type": "string" },
        "subject": { "type": "string" },
        "teacher": { "type": "string" },
        "timeSlot": { "type": "string" },
        "room": { "type": "string" }
      },
      "required": ["id", "grade", "day", "subject", "teacher", "timeSlot", "room"]
    }
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": "student",
      "description": "List of all enrolled students."
    },
    "/teachers/{teacherId}": {
      "schema": "teacher",
      "description": "Active full-time educators."
    },
    "/libraryBooks/{bookId}": {
      "schema": "libraryBook",
      "description": "Library asset list."
    },
    "/timetable/{slotId}": {
      "schema": "timetableEntry",
      "description": "Academic scheduling entries."
    }
  }
}
